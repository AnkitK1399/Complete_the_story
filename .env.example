# Google Gemini API Configuration
# Replace with your own API key. DO NOT commit your actual key to git!
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Broker Configuration (default for docker-compose is redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0

# Database Configuration (SQLite default)
DATABASE_URL=sqlite:///./complete_the_story.db
